# Reddit API credentials
# Create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USERNAME=your_bot_account_username
REDDIT_PASSWORD=your_bot_account_password

# User-agent string (Reddit requires a descriptive one)
REDDIT_USER_AGENT=ScamSentry/0.1 by u/your_username

# Comma-separated list of subreddits to monitor
SUBREDDITS=your_test_subreddit

# Risk score threshold (0–100). Posts at or above this are flagged.
RISK_THRESHOLD=70

# Action mode:
#   none  — log only, no mod actions
#   flair — apply flair to flagged posts (bot must be a moderator)
ACTION_MODE=none

# Flair settings (only used when ACTION_MODE=flair)
FLAG_FLAIR_TEXT=⚠️ Possible Scam
FLAG_FLAIR_CSS=possible-scam

# SQLite database file path
DB_PATH=./sentry.db

# How long (seconds) to cache Reddit user profile data (default: 6 hours)
USER_CACHE_TTL_SECONDS=21600
